<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security configuration — story 1.1 AC5, NFR-S1.

    This file is the platform-level enforcement layer. App code (Dio + cert
    pinning interceptor) is defense-in-depth; this manifest-bound config is
    the *last* chance to refuse plaintext or a bad cert, even if app code
    regresses.

    Scope for story 1.1 is the SKELETON — real SPKI pins are owned by story
    1.3 (Security Primitives — Dio & Cert Pinning). The `<domain-config>`
    shell is present so the manifest wire-up (`@xml/network_security_config`)
    is exercised today; `<pin-set>` is intentionally absent until Story 1.3
    lands real digests. JIT: a placeholder pin-set is either inert (expired)
    or wrong (blocking TLS) — neither serves the guard-rail intent.

    Rationale for `cleartextTrafficPermitted="false"` at base-config scope:
    there is no legitimate HTTP traffic in prijavko — eVisitor is HTTPS-only,
    AdMob/UMP is HTTPS-only, Firebase is HTTPS-only. A single cleartext leak
    (e.g. a dev URL with http://) must fail at the platform layer.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
        eVisitor domain — <pin-set> added by Story 1.3 once real SPKI SHA-256
        digests for the evisitor.hr leaf + intermediate are known. Until then
        this domain-config is intentionally empty: it exists so Story 1.3's
        change is a single additive edit, not a file creation.
    -->
    <domain-config>
        <domain includeSubdomains="true">www.evisitor.hr</domain>
    </domain-config>
</network-security-config>
