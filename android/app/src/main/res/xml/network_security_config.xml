<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security configuration — story 1.1 AC5, NFR-S1.

    This file is the platform-level enforcement layer. App code (Dio + cert
    pinning interceptor) is defense-in-depth; this manifest-bound config is
    the *last* chance to refuse plaintext or a bad cert, even if app code
    regresses.

    Scope for story 1.1 is the SKELETON — real pin values are owned by
    story 1.3 (Security Primitives — Dio & Cert Pinning). Until then, the
    <pin-set> block below carries placeholder digests that are intentionally
    wrong so any accidental shipping of this stub before 1.3 lands will hard-
    fail TLS to evisitor.hr rather than silently accept any cert.

    Rationale for `cleartextTrafficPermitted="false"` at base-config scope:
    there is no legitimate HTTP traffic in prijavko — eVisitor is HTTPS-only,
    AdMob/UMP is HTTPS-only, Firebase is HTTPS-only. A single cleartext leak
    (e.g. a dev URL with http://) must fail at the platform layer.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
        eVisitor domain — pins to be populated by story 1.3.
        Until then, the expiration is set to a near-past date so the pin set
        is considered expired and falls back to base-config trust anchors,
        keeping the skeleton non-blocking for CI smoke builds while preserving
        the file/manifest wiring this story is responsible for.
    -->
    <domain-config>
        <domain includeSubdomains="true">www.evisitor.hr</domain>
        <pin-set expiration="2026-04-24">
            <!-- PLACEHOLDER — real SPKI SHA-256 pins land in story 1.3. -->
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
            <pin digest="SHA-256">BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=</pin>
        </pin-set>
    </domain-config>
</network-security-config>
