{
  "name": "mock-evisitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22 <23" },
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/server.ts",
    "start": "node --experimental-strip-types src/server.ts",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "test": "node --experimental-strip-types --test --test-reporter=tap $(find test -name '*.test.ts')"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/formbody": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "fast-xml-parser": "^4.5.0"
  }
}
